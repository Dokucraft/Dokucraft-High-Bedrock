      "minecraft:particle_appearance_billboard": {
        "size": [
          {"expression": "v.particle_random_1 > 0.5 ? 0.05 : 0.075", "version": 9},
          {"expression": "v.particle_random_1 > 0.5 ? 0.05 : 0.075", "version": 9}
